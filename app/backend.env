# Multimodal RAG Backend – Environment Variables

APP_TITLE=Multimodal RAG Backend

# Models
LLM_MODEL=llama3.2
OCR_MODEL=deepseek-ocr:latest
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Retrieval settings
TOP_K=5
HYBRID_ALPHA=0.7
CANDIDATE_MULTIPLIER=4

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=100
MAX_CONTEXT_CHARS=6000

# OCR
OCR_ZOOM=2
OCR_MIN_NATIVE_TEXT_CHARS=80
OCR_MAX_WORKERS=4
OCR_MAX_IMAGE_SIZE=800
PREVIEW_CHARS=200

# Persistence
FAISS_INDEX_DIR=faiss_index
STORAGE_DIR=storage

# Cross-encoder blending
CE_WEIGHT=0.5

# Enrichment
ENABLE_ENRICHMENT=true

# Evaluation dataset (path relative to project root)
EVALUATION_SET_FILE=evaluation_set.json

# Advanced retrieval
DYNAMIC_ALPHA=true
ENABLE_QUERY_REWRITE=true